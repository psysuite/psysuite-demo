<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFF3E0"
        tools:context=".view.MainFragment">

    <!-- Top row buttons -->
    <Button
        android:id="@+id/bt_start_temporal_test"
        style="@style/Base.Widget.AppCompat.Button.Colored"
        android:layout_width="0dp"
        android:layout_height="@dimen/main_button_height"
        android:layout_marginStart="16dp"
        android:layout_marginTop="@dimen/main_button_margin_top"
        android:layout_marginEnd="8dp"
        android:enabled="true"
        android:text="@string/label_temporal_tests"
        android:textSize="@dimen/main_button_text_size"
        app:layout_constraintEnd_toStartOf="@+id/bt_start_prediction_test"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/bt_start_prediction_test"
        style="@style/Base.Widget.AppCompat.Button.Colored"
        android:layout_width="0dp"
        android:layout_height="@dimen/main_button_height"
        android:layout_marginStart="8dp"
        android:layout_marginTop="@dimen/main_button_margin_top"
        android:layout_marginEnd="16dp"
        android:enabled="true"
        android:text="@string/label_prediction_tests"
        android:textSize="@dimen/main_button_text_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/bt_start_temporal_test"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Bottom row buttons -->
    <Button
        android:id="@+id/bt_start_illusion_test"
        style="@style/Widget.AppCompat.Button.Colored"
        android:layout_width="0dp"
        android:layout_height="@dimen/main_button_height"
        android:layout_marginStart="16dp"
        android:layout_marginTop="@dimen/main_button_margin_top"
        android:layout_marginEnd="8dp"
        android:enabled="true"
        android:text="@string/label_illusion_tests"
        android:textColorLink="@color/colorAccent"
        android:textSize="@dimen/main_button_text_size"
        app:layout_constraintEnd_toStartOf="@+id/bt_start_various_test"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bt_start_temporal_test" />

    <Button
        android:id="@+id/bt_start_various_test"
        style="@style/Base.Widget.AppCompat.Button.Colored"
        android:layout_width="0dp"
        android:layout_height="@dimen/main_button_height"
        android:layout_marginStart="8dp"
        android:layout_marginTop="@dimen/main_button_margin_top"
        android:layout_marginEnd="16dp"
        android:enabled="true"
        android:text="@string/label_miscellaneous_tests"
        android:textSize="@dimen/main_button_text_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/bt_start_illusion_test"
        app:layout_constraintTop_toBottomOf="@+id/bt_start_prediction_test" />

    <!-- Bottom labels -->
    <TextView
        android:id="@+id/labVersion"
        android:layout_width="150dp"
        android:layout_height="29dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="4dp"
        android:text="TextView"
        android:textAlignment="textEnd"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/labRegName"
        android:layout_width="150dp"
        android:layout_height="29dp"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="4dp"
        android:textAlignment="textStart"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>