            android:key="web_upload_status"
            android:title="Web Upload Status"
            android:summary="Not configured"
            android:selectable="false" />
            
    </PreferenceCategory>

    <PreferenceCategory android:title="Email Results">

        <SwitchPreferenceCompat
            android:key="email_enabled"
            android:title="Enable Email Sending"
            android:summary="Allow sending results via email"
            android:defaultValue="false" />

        <EditTextPreference
            android:defaultValue="@string/main_email"
            android:key="pref_main_email"
            android:selectAllOnFocus="true"
            android:singleLine="true"
            android:title="Main e-mail address"
            android:dependency="email_enabled" />
    </PreferenceCategory>

    <PreferenceCategory android:title="Stimuli reciprocal delays">

        <EditTextPreference
            android:inputType="number"
            android:key="pref_delay_a1"
            android:selectAllOnFocus="true"
            android:singleLine="true"
            android:title="Audio1"
            android:defaultValue="0"
            app:useSimpleSummaryProvider="true"/>

        <EditTextPreference
            android:inputType="number"
            android:key="pref_delay_a2"
            android:selectAllOnFocus="true"
            android:singleLine="true"
            android:title="Audio2"
            android:defaultValue="0"
            app:useSimpleSummaryProvider="true"/>

        <EditTextPreference
            android:inputType="number"
            android:key="pref_delay_a3"
            android:selectAllOnFocus="true"
            android:singleLine="true"
            android:title="Audio3"
            android:defaultValue="0"
            app:useSimpleSummaryProvider="true"/>

        <EditTextPreference
            android:inputType="number"
            android:key="pref_delay_t1"
            android:selectAllOnFocus="true"
            android:singleLine="true"
            android:title="Tactile1"
            android:defaultValue="0"
            app:useSimpleSummaryProvider="true"/>
        <EditTextPreference
            android:inputType="number"
            android:key="pref_delay_t2"
            android:selectAllOnFocus="true"
            android:singleLine="true"
            android:title="Tactile2"
            android:defaultValue="0"
            app:useSimpleSummaryProvider="true"/>

        <EditTextPreference
            android:inputType="number"
            android:key="pref_delay_v1"
            android:selectAllOnFocus="true"
            android:singleLine="true"
            android:title="Visual1"
            android:defaultValue="0"
            app:useSimpleSummaryProvider="true"/>

        <EditTextPreference
            android:inputType="number"
            android:key="pref_delay_v2"
            android:selectAllOnFocus="true"
            android:singleLine="true"
            android:title="Visual2"
            android:defaultValue="0"
            app:useSimpleSummaryProvider="true"/>

    </PreferenceCategory>



</PreferenceScreen>


