<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".MainFragment">


    <Button
            android:id="@+id/bt_start_tid_test"
            style="@style/Widget.AppCompat.Button.Colored"
            android:layout_width="380dp"
            android:layout_height="100dp"
            android:layout_marginTop="12dp"
            android:enabled="true"
            android:text="@string/tid_label"
            android:textColorLink="@color/colorAccent"
            android:textSize="24sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.516"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/bt_start_musicalmeter" />

    <Button
            android:id="@+id/bt_start_bisection"
            style="@style/Base.Widget.AppCompat.Button.Colored"
            android:layout_width="380dp"
            android:layout_height="100dp"
            android:layout_marginTop="12dp"
            android:enabled="true"
            android:text="@string/start_bisection"
            android:textSize="24sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.516"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/bt_start_atvb_test" />

    <Button
            android:id="@+id/bt_start_musicalmeter"
            style="@style/Base.Widget.AppCompat.Button.Colored"
            android:layout_width="380dp"
            android:layout_height="100dp"
            android:layout_marginTop="12dp"
            android:enabled="true"
            android:text="@string/start_musicalmeter"
            android:textSize="24sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.483"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/bt_start_bisection" />

    <Button
            android:id="@+id/bt_start_atb_test"
            style="@style/Base.Widget.AppCompat.Button.Colored"
            android:layout_width="380dp"
            android:layout_height="100dp"
            android:layout_marginTop="12dp"
            android:enabled="true"
            android:text="@string/start_atb"
            android:textSize="24sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.483"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    <Button
            android:id="@+id/bt_start_atvb_test"
            style="@style/Base.Widget.AppCompat.Button.Colored"
            android:layout_width="380dp"
            android:layout_height="100dp"
            android:layout_marginTop="12dp"
            android:text="@string/start_atvb"
            android:textSize="24sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.483"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/bt_start_atb_test" />


</androidx.constraintlayout.widget.ConstraintLayout>