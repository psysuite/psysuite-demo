<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".view.MainFragment">


    <Button
        android:id="@+id/bt_start_tid_test"
        style="@style/Base.Widget.AppCompat.Button.Colored"
        android:layout_width="@dimen/main_button_width"
        android:layout_height="@dimen/main_button_height"
        android:layout_marginTop="@dimen/main_button_margin_top"
        android:enabled="true"
        android:text="@string/tid_label"
        android:textSize="@dimen/main_button_text_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bt_start_bindings" />

    <Button
        android:id="@+id/bt_start_bindings"
        style="@style/Base.Widget.AppCompat.Button.Colored"
        android:layout_width="@dimen/main_button_width"
        android:layout_height="@dimen/main_button_height"
        android:layout_marginTop="40dp"
        android:enabled="true"
        android:text="@string/label_bindings"
        android:textSize="@dimen/main_button_text_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <Button
        android:id="@+id/bt_start_tir_test"
        style="@style/Base.Widget.AppCompat.Button.Colored"
        android:layout_width="@dimen/main_button_width"
        android:layout_height="@dimen/main_button_height"
        android:layout_marginTop="@dimen/main_button_margin_top"
        android:text="@string/tir_label"
        android:textSize="@dimen/main_button_text_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bt_start_bis" />

    <Button
        android:id="@+id/bt_start_bis"
        style="@style/Base.Widget.AppCompat.Button.Colored"
        android:layout_width="@dimen/main_button_width"
        android:layout_height="@dimen/main_button_height"
        android:layout_marginTop="@dimen/main_button_margin_top"
        android:text="@string/start_bisection"
        android:textSize="@dimen/main_button_text_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bt_start_tid_test" />
</androidx.constraintlayout.widget.ConstraintLayout>