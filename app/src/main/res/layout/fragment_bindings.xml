<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E8F5E8"
        tools:context=".view.MainFragment">


    <!-- Button 1: ATB Test (top) -->
    <Button
        android:id="@+id/bt_start_atb_test"
        style="@style/Base.Widget.AppCompat.Button.Colored"
        android:layout_width="@dimen/main_button_width"
        android:layout_height="@dimen/main_button_height"
        android:layout_marginTop="40dp"
        android:text="@string/start_atb"
        android:textSize="@dimen/main_button_text_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Button 2: TVB Test -->
    <Button
        android:id="@+id/bt_start_tvb_test"
        style="@style/Base.Widget.AppCompat.Button.Colored"
        android:layout_width="@dimen/main_button_width"
        android:layout_height="@dimen/main_button_height"
        android:layout_marginTop="@dimen/main_button_margin_top"
        android:text="@string/start_tvb"
        android:textSize="@dimen/main_button_text_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bt_start_atb_test" />

    <!-- Button 3: AVB Test -->
    <Button
        android:id="@+id/bt_start_avb_test"
        style="@style/Base.Widget.AppCompat.Button.Colored"
        android:layout_width="@dimen/main_button_width"
        android:layout_height="@dimen/main_button_height"
        android:layout_marginTop="@dimen/main_button_margin_top"
        android:text="@string/start_avb"
        android:textSize="@dimen/main_button_text_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bt_start_tvb_test" />

    <!-- Button 4: ATVB Test (bottom) -->
    <Button
        android:id="@+id/bt_start_atvb_test"
        style="@style/Base.Widget.AppCompat.Button.Colored"
        android:layout_width="@dimen/main_button_width"
        android:layout_height="@dimen/main_button_height"
        android:layout_marginTop="@dimen/main_button_margin_top"
        android:text="@string/start_atvb"
        android:textSize="@dimen/main_button_text_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bt_start_avb_test" />
</androidx.constraintlayout.widget.ConstraintLayout>