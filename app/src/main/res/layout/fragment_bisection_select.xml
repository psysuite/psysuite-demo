<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
                                                   xmlns:app="http://schemas.android.com/apk/res-auto"
                                                   xmlns:tools="http://schemas.android.com/tools"
                                                   android:layout_width="match_parent"
                                                   android:layout_height="match_parent"
                                                   tools:context=".fragments.BisectionSelectFragment"
                                                   android:background="@color/design_default_color_background">


    <Button
            android:id="@+id/bt_bisection_audio"
            style="@style/Base.Widget.AppCompat.Button.Colored"
            android:layout_width="363dp"
            android:layout_height="140dp"
            android:text="AUDIO TEST"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toTopOf="parent" android:layout_marginStart="8dp"
            app:layout_constraintStart_toStartOf="parent" android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toEndOf="parent" android:textSize="24sp"/>

    <Button
            android:id="@+id/bt_bisection_tactile"
            style="@style/Base.Widget.AppCompat.Button.Colored"
            android:layout_width="363dp"
            android:layout_height="140dp"
            android:text="TACTILE TEST"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/bt_bisection_audio" android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toEndOf="parent" android:layout_marginStart="8dp"
            app:layout_constraintStart_toStartOf="parent" android:textSize="24sp"/>

    <Button
            android:id="@+id/bt_bisection_audio_tactile"
            style="@style/Base.Widget.AppCompat.Button.Colored"
            android:layout_width="363dp"
            android:layout_height="140dp"
            android:text="AUDIO + TACTILE TEST"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@+id/bt_bisection_tactile" android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toEndOf="parent" android:layout_marginStart="8dp"
            app:layout_constraintStart_toStartOf="parent" android:textSize="24sp"/>

    <Button
            android:id="@+id/bt_bisection_audio_video"
            style="@style/Base.Widget.AppCompat.Button.Colored"
            android:layout_width="363dp"
            android:layout_height="140dp"
            android:text="AUDIO + VIDEO TEST"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@+id/bt_bisection_audio_tactile" android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toEndOf="parent" android:layout_marginStart="8dp"
            app:layout_constraintStart_toStartOf="parent" android:textSize="24sp"/>
</androidx.constraintlayout.widget.ConstraintLayout>